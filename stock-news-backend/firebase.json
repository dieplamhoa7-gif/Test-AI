{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "firebase_public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=60" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://hoa-investment.onrender.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://firestore.googleapis.com https://www.googleapis.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/", "destination": "/stocks.html" },
      { "source": "/stocks", "destination": "/stocks.html" },
      { "source": "/stocks/**", "destination": "/stocks.html" },
      { "source": "/warrants", "destination": "/warrants.html" },
      { "source": "/warrants/**", "destination": "/warrants.html" },
      { "source": "/news-page", "destination": "/news-page.html" },
      { "source": "/account", "destination": "/account.html" }
    ]
  }
}
